{
  "manifest_version": 3,
  "name": "赚钱助手 - 股票&基金持仓管理",
  "version": "1.4.3",
  "description": "是你赚钱路上的最重要的小帮手",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://qt.gtimg.cn/*",
    "https://web.ifzq.gtimg.cn/*",
    "https://smartbox.gtimg.cn/*",
    "https://fund.eastmoney.com/*",
    "https://fundcomapi.tiantianfunds.com/*",
    "https://fundgz.1234567.com.cn/*",
    "https://fundmobapi.eastmoney.com/*",
    "https://push2.eastmoney.com/*",
    "https://push2his.eastmoney.com/*",
    "https://40.push2.eastmoney.com/*",
    "https://vip.stock.finance.sina.com.cn/*"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "public/icon16.png",
      "32": "public/icon32.png",
      "48": "public/icon48.png",
      "128": "public/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts"
  },
  "options_page": "src/options/index.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/floating-overlay/content.tsx"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["public/icon16.png", "public/icon32.png", "public/icon48.png", "public/icon128.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "public/icon16.png",
    "32": "public/icon32.png",
    "48": "public/icon48.png",
    "128": "public/icon128.png"
  }
}
