{
  "manifest_version": 3,
  "name": "Stock Tracker - 股票持仓管理",
  "version": "1.0.0",
  "description": "基于腾讯财经的股票持仓管理工具",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://qt.gtimg.cn/*"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "public/icon16.svg",
      "32": "public/icon32.svg",
      "48": "public/icon48.svg",
      "128": "public/icon128.svg"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts"
  },
  "options_page": "src/options/index.html",
  "icons": {
    "16": "public/icon16.svg",
    "32": "public/icon32.svg",
    "48": "public/icon48.svg",
    "128": "public/icon128.svg"
  }
}
